# ============================================================
# Forma — Environment Variables
# Copy this to .env.local (Next.js) and backend/.env
# ============================================================

# ── Frontend (Next.js / Vercel) ───────────────────────────────
# Add these in Vercel Dashboard > Settings > Environment Variables

NEXT_PUBLIC_SUPABASE_URL=https://adlmjdfmxpnehegxoana.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-from-supabase-dashboard
NEXT_PUBLIC_API_URL=https://forma-api.onrender.com

# ── Backend (FastAPI / Render) ────────────────────────────────
# Add these in Render Dashboard > Environment

SUPABASE_URL=https://adlmjdfmxpnehegxoana.supabase.co
SUPABASE_KEY=your-anon-key-from-supabase-dashboard
SUPABASE_SERVICE_KEY=your-service-role-key-from-supabase-dashboard
JWT_SECRET=your-jwt-secret-minimum-32-characters-long-random-string
REDIS_URL=redis://localhost:6379
CORS_ORIGINS=https://forma-71ny.vercel.app,http://localhost:3000
ENV=development

# ── Where to find keys ────────────────────────────────────────
# Supabase keys: https://supabase.com/dashboard/project/adlmjdfmxpnehegxoana/settings/api-keys
# SUPABASE_KEY = anon/public key (safe to use in frontend)
# SUPABASE_SERVICE_KEY = service_role key (NEVER expose in frontend!)
